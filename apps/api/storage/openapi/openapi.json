{
    "openapi": "3.1.0",
    "info": {
        "title": "Cognify API",
        "version": "0.1.0"
    },
    "paths": {
        "/api/health": {
            "get": {
                "operationId": "getHealth",
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "API is healthy",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HealthResponse"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "HealthResponse": {
                "type": "object",
                "required": ["status", "service"],
                "properties": {
                    "status": {
                        "type": "string",
                        "const": "ok"
                    },
                    "service": {
                        "type": "string",
                        "const": "cognify-api"
                    }
                }
            }
        }
    }
}
