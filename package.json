{
  "name": "cognify",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:reset": "node tooling/scripts/dev-reset.mjs",
    "dev:proxy": "node tooling/scripts/dev-proxy.mjs",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:api": "pnpm --filter @cognify/api-client generate",
    "check:api-contract": "pnpm --filter @cognify/api-client check:contract",
    "api:test": "cd apps/api && php artisan test",
    "api:routes": "cd apps/api && php artisan route:list --path=api",
    "dev:services": "node tooling/scripts/dev-services.mjs up",
    "dev:services:down": "node tooling/scripts/dev-services.mjs down"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3"
  }
}
